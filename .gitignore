# Secrets (jangan pernah commit)
# ═════════════════════════════════════════════════════════════
*.pem
*.key
*.p12
*.pfx
*.cert
.env*
!.env.example
credentials.json
secrets.json
config.local.*
firebase-service-account.json
google-services.json
GoogleService-Info.plist
