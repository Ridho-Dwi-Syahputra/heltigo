# ML Service Config
ML_SERVICE_KEY=dev-shared-secret-change-in-prod
PORT=8001

# Gemini AI (untuk food scan - Model 4)
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model artifacts base path (opsional)
# Default: auto-detect dari posisi ml-service/ → ../notebook/training_model/
# Isi jika artifacts ada di lokasi berbeda (absolute path)
MODEL_BASE_PATH=
